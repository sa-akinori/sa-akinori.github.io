---
import SocialLinks from './SocialLinks.astro';
import { getLangFromUrl, useTranslations } from '../i18n';
import { labUrl } from '../data/profile';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="relative isolate overflow-hidden">
  <div
    class="absolute inset-0 -z-20 bg-cover bg-center"
    style="background-image: url('/images/hero-bg.png')"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-r from-white/95 via-white/80 to-transparent"
    aria-hidden="true"
  ></div>
  <div class="mx-auto flex min-h-[28rem] max-w-5xl items-center px-6 py-20 md:min-h-[32rem] md:py-28">
    <div class="max-w-md">
      <h1 class="text-5xl font-bold tracking-tight text-slate-900 md:text-6xl">
        {t('hero.name')}
      </h1>
      <p class="mt-3 text-base font-medium text-slate-700">
        {t('hero.position')}
      </p>
      <p class="mt-2 whitespace-pre-line text-sm leading-relaxed text-slate-600">
        {t('hero.affiliation')}
      </p>
      <p class="mt-1 text-sm leading-relaxed">
        <a
          href={labUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-blue-700 underline-offset-2 hover:underline"
        >
          {t('hero.lab')}
        </a>
      </p>
      <p class="mt-6 text-xl font-medium text-slate-700 md:text-2xl">
        {t('hero.tagline')}
      </p>
      <p class="mt-6 text-base text-slate-600">
        {t('hero.description')}
      </p>
      <div class="mt-8">
        <SocialLinks />
      </div>
    </div>
  </div>
</section>
