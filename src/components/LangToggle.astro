---
import { getLangFromUrl, altLangUrl, useTranslations } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const href = altLangUrl(Astro.url, lang);
---
<a
  href={href}
  class="rounded-full border border-slate-300 px-3 py-1 text-xs font-medium text-slate-700 transition hover:border-blue-600 hover:text-blue-700"
>
  {t('lang.toggle')}
</a>
