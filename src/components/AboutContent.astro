---
import { getLangFromUrl, useTranslations } from '../i18n';
import {
  position,
  education,
  career,
  researchFields,
  researchKeywords,
  researchmapUrl,
} from '../data/profile';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="mx-auto max-w-3xl px-6 py-20">
  <h1 class="text-4xl font-bold tracking-tight text-slate-900">{t('about.title')}</h1>

  <dl class="mt-12 space-y-12">
    <div>
      <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">
        {t('about.position')}
      </dt>
      <dd class="mt-3 text-slate-700">{position[lang]}</dd>
    </div>

    <div>
      <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">
        {t('about.career')}
      </dt>
      <dd class="mt-3">
        <ul class="space-y-3">
          {career.map((item) => (
            <li class="flex flex-col gap-1 sm:flex-row sm:gap-6">
              <span class="shrink-0 font-mono text-sm text-slate-500 sm:w-28">{item.period}</span>
              <span class="text-slate-700">{item.text[lang]}</span>
            </li>
          ))}
        </ul>
      </dd>
    </div>

    <div>
      <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">
        {t('about.education')}
      </dt>
      <dd class="mt-3">
        <ul class="space-y-3">
          {education.map((item) => (
            <li class="flex flex-col gap-1 sm:flex-row sm:gap-6">
              <span class="shrink-0 font-mono text-sm text-slate-500 sm:w-28">{item.period}</span>
              <span class="text-slate-700">{item.text[lang]}</span>
            </li>
          ))}
        </ul>
      </dd>
    </div>

    <div>
      <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">
        {t('about.fields')}
      </dt>
      <dd class="mt-3 text-slate-700">
        {researchFields.map((field, i) => (
          <span>
            {i > 0 && <span class="text-slate-400"> ／ </span>}
            {field[lang]}
          </span>
        ))}
      </dd>
    </div>

    <div>
      <dt class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">
        {t('about.keywords')}
      </dt>
      <dd class="mt-3 flex flex-wrap gap-2">
        {researchKeywords.map((kw) => (
          <span class="rounded-full bg-blue-50 px-3 py-1 text-sm text-blue-800">{kw[lang]}</span>
        ))}
      </dd>
    </div>
  </dl>

  <p class="mt-12">
    <a
      href={researchmapUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm text-blue-700 hover:underline"
    >
      {t('about.researchmap')}
    </a>
  </p>
</section>
