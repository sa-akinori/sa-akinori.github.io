---
import { getLangFromUrl, useTranslations } from '../i18n';
import { peerReviewedPapers, miscPapers, researchmapUrl } from '../data/profile';
import type { Paper } from '../data/profile';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

function formatPaper(p: Paper): string {
  const venuePart = p.venue ? `, ${p.venue}` : '';
  return `${p.authors}. "${p.title}"${venuePart}, ${p.year}.`;
}
---
<section class="mx-auto max-w-3xl px-6 py-20">
  <h1 class="text-4xl font-bold tracking-tight text-slate-900">{t('publications.title')}</h1>

  <h2 class="mt-12 text-2xl font-semibold tracking-tight text-slate-900">
    {t('publications.peerReviewed')}
  </h2>
  <ol class="mt-6 space-y-5">
    {peerReviewedPapers.map((p, i) => (
      <li class="flex gap-4 text-slate-700">
        <span class="shrink-0 font-mono text-sm text-slate-500">[{peerReviewedPapers.length - i}]</span>
        <p class="leading-relaxed">
          {formatPaper(p)}
          {p.firstAuthor && (
            <span class="ml-2 inline-block rounded bg-blue-50 px-1.5 py-0.5 align-middle text-xs font-medium text-blue-800">
              {lang === 'ja' ? '筆頭著者' : 'First author'}
            </span>
          )}
        </p>
      </li>
    ))}
  </ol>

  {miscPapers.length > 0 && (
    <>
      <h2 class="mt-16 text-2xl font-semibold tracking-tight text-slate-900">
        {t('publications.misc')}
      </h2>
      <ol class="mt-6 space-y-5">
        {miscPapers.map((p, i) => (
          <li class="flex gap-4 text-slate-700">
            <span class="shrink-0 font-mono text-sm text-slate-500">[{miscPapers.length - i}]</span>
            <p class="leading-relaxed">{formatPaper(p)}</p>
          </li>
        ))}
      </ol>
    </>
  )}

  <p class="mt-16">
    <a
      href={researchmapUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm text-blue-700 hover:underline"
    >
      {lang === 'ja' ? 'researchmap で全業績を見る →' : 'View full publication list on researchmap →'}
    </a>
  </p>
</section>
